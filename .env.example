# HJS API Environment Configuration
# Copy this file to .env and fill in your values

# Database connection string
# Format: postgresql://username:password@host:port/database_name
# Examples:
#   Local PostgreSQL: postgresql://localhost:5432/hjs_dev
#   Render PostgreSQL: postgresql://user:pass@host:port/db
DATABASE_URL=postgresql://localhost:5432/hjs_dev

# Server port (optional, defaults to 3000)
PORT=3000

# API base URL (for generating links in emails, PDFs, etc.)
# In development: http://localhost:3000
# In production: https://api.hjs.sh
API_BASE=http://localhost:3000

# Node environment
# Options: development, production
NODE_ENV=development

# ⏱️ Immutability Anchoring (IETF Draft Section 6.1.1)
# HJS supports optional timestamp anchoring via OpenTimestamps.
# This implements the "immutability" field defined in the protocol.
# To enable, uncomment and set your preferred OTS calendar server.
# Multiple calendars can be comma-separated.
# 
# Reference: https://datatracker.ietf.org/doc/draft-wang-hjs-judgment-event/#section-6.1.1
# 
# Examples:
#   - https://btc.calendar.catallaxy.com
#   - https://a.pool.opentimestamps.org
#   - https://b.pool.opentimestamps.org
#
# OTS_CALENDAR=https://btc.calendar.catallaxy.com
